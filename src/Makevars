# Base TMB headers
PKG_CPPFLAGS = -I$(shell $(R_HOME)/bin/Rscript -e "cat(system.file('include', package='TMB'))") \
               -I$(shell $(R_HOME)/bin/Rscript -e "cat(system.file('include', package='RcppEigen'))") \
               -fopenmp

# Linker flags
PKG_LIBS = -fopenmp $(LAPACK_LIBS) $(BLAS_LIBS) $(FLIBS) \
           -L$(shell $(R_HOME)/bin/Rscript -e "cat(system.file('libs', package='TMB'))") -lTMB