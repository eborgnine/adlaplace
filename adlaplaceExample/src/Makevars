ADLAPLACE_INCLUDE = $(shell Rscript -e "p <- system.file('include', package='adlaplace'); if (!nzchar(p)) { fp <- suppressWarnings(find.package('adlaplace', quiet=TRUE)); if (length(fp)) p <- file.path(fp[1], 'include') }; cat(p)")
PKG_CPPFLAGS = -I../inst/include -I$(ADLAPLACE_INCLUDE) -DCPPAD_HAS_COLPACK=0 -I/opt/homebrew/opt/libomp/include -I/opt/homebrew/include -isystem /Library/Frameworks/R.framework/Versions/4.5-arm64/Resources/library/RcppEigen/include
PKG_CXXFLAGS = -Xpreprocessor -fopenmp
PKG_LIBS     = /opt/homebrew/opt/libomp/lib/libomp.dylib -Wl,-rpath,/opt/homebrew/opt/libomp/lib
